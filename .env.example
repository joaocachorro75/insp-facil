# Groq Vision API Key - Para análise de imagens com IA
# Obtenha sua chave em: https://console.groq.com/
GROQ_VISION_KEY="YOUR_GROQ_VISION_KEY"

# Groq Transcription API Key - Para transcrição de áudio
GROQ_TRANSCRIPTION_KEY="YOUR_GROQ_TRANSCRIPTION_KEY"

# APP_URL - URL onde o app está hospedado
APP_URL="https://inspfacil.to-ligado.com"

# Evolution API Configuration (WhatsApp)
EVOLUTION_API_URL="YOUR_EVOLUTION_API_URL"
EVOLUTION_API_KEY="YOUR_EVOLUTION_API_KEY"
EVOLUTION_INSTANCE_NAME="inspfacil"

# Port (default 3000)
PORT=3000
